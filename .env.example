# Copie para `.env` na raiz (não commite segredos reais).
# Obrigatório para `docker compose up` (POSTGRES_PASSWORD e LOJAPP_JWT_SECRET).
#
# Gerar segredos fortes (exemplos):
#   Linux/macOS: openssl rand -base64 32
#   PowerShell:  -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})

# PostgreSQL — alinhar POSTGRES_PASSWORD com SPRING_DATASOURCE_PASSWORD no mesmo `.env`.
# docker-compose.yml (dev) usa loja_db / loja_user; para `mvn spring-boot:run` com Postgres do Compose:
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/loja_db
SPRING_DATASOURCE_USERNAME=loja_user
SPRING_DATASOURCE_PASSWORD=
POSTGRES_PASSWORD=

# Redis (rate limit distribuído; obrigatório se LOJAPP_RATE_LIMIT_MODE=redis)
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# JWT — mínimo ~32 caracteres; obrigatório (ver ProductionSecurityConfig)
LOJAPP_JWT_SECRET=
# Access token (ms). Default em application.yml ~15 min; não aumentar sem motivo em produção.
# LOJAPP_JWT_EXPIRATION_MS=900000
# LOJAPP_JWT_REFRESH_EXPIRATION_MS=1209600000

# CORS — origens do frontend, separadas por vírgula
LOJAPP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Registo público — default seguro é false. Em dev local pode usar true.
# LOJAPP_REGISTRATION_ENABLED=false
# Domínios permitidos após @ (CSV). Vazio = qualquer domínio (só se enabled=true).
# LOJAPP_REGISTRATION_ALLOWED_DOMAINS=
# LOJAPP_REGISTRATION_MAX_PER_IP_PER_HOUR=10
# Segredo partilhado: se definido, POST /register exige JSON inviteToken igual (alternativa leve a CAPTCHA).
# LOJAPP_REGISTRATION_INVITE_SECRET=

# Cookie de refresh — mapeia `lojapp.auth.refresh-cookie-secure`; em produção com HTTPS: true
# LOJAPP_AUTH_REFRESH_COOKIE_SECURE=false

# Armazenamento XML NFe: database | s3 (ver application.yml lojapp.nfe.storage)
# LOJAPP_NFE_STORAGE_BACKEND=database
# LOJAPP_NFE_STORAGE_S3_ENDPOINT=
# LOJAPP_NFE_STORAGE_S3_BUCKET=lojapp-nfe-xml

# Opcional: LOJAPP_RATE_LIMIT_MODE=memory|redis (em docker-compose local usa redis)

# Opcional frontend (Vite)
# VITE_API_BASE=http://localhost:8000
